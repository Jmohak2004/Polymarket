APP_ENV=development
SECRET_KEY=change_me_in_production

# Comma-separated origins for browser CORS (e.g. https://app.example.com). If omitted,
# APP_ENV=development allows "*"; production does not wildcard — set origins explicitly.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Blockchain
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
ORACLE_PRIVATE_KEY=your_oracle_wallet_private_key
PREDICTION_MARKET_ADDRESS=0x0000000000000000000000000000000000000000
ORACLE_RESOLVER_ADDRESS=0x0000000000000000000000000000000000000000

# AI APIs
OPENAI_API_KEY=sk-...
ASSEMBLYAI_API_KEY=...
GOOGLE_SPEECH_API_KEY=...

# Web source discovery (one recommended for production; DDG is fallback, rate-limited)
TAVILY_API_KEY=tvly-...
# SERPAPI_KEY=...
# GOOGLE_CSE_ID=...   # with GOOGLE_CSE_API_KEY=...
# GOOGLE_CSE_API_KEY=...
# BRAVE_SEARCH_API_KEY=BSA...    # from https://brave.com/search/api/

# Weather
OPENWEATHER_API_KEY=...
TOMORROW_IO_API_KEY=...

# Redis (task queue)
REDIS_URL=redis://localhost:6379/0

# Database
DATABASE_URL=sqlite+aiosqlite:///./polymarket.db
