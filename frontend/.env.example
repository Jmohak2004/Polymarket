# Copy to `.env.local` and adjust values.
#
# Backend API used by fetch() in `src/lib/api.ts`
NEXT_PUBLIC_API_URL=http://localhost:8000

# Chain ID where PredictionMarket is deployed (e.g. 31337 Hardhat, 80002 Amoy).
# Omit to skip wallet ↔ env network checks (useful for prototyping).
NEXT_PUBLIC_CHAIN_ID=31337

# Deployed PredictionMarket contract (checksum address). Required for on-chain bets
# and related UI in `src/lib/predictionMarket.ts`. Leave unset for API-only browsing.
NEXT_PUBLIC_PREDICTION_MARKET_ADDRESS=0x0000000000000000000000000000000000000000

# Block explorer base URL (no /tx suffix). Omit for localhost / no-links mode.
NEXT_PUBLIC_CHAIN_EXPLORER=https://amoy.polygonscan.com

# Public site origin for absolute OG URLs and metadata (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3001
